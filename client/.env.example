# ── HostelHub client (Vite) ───────────────────────────────────────────────
# All client env vars MUST be prefixed with VITE_ to be exposed to the app.

# API base URL.
#  - Leave UNSET for same-origin deploys (dev proxy, or Docker behind one reverse proxy):
#    the app calls "/api" on its own origin.
#  - For a SPLIT deploy (frontend and backend on different origins, e.g.
#    Vercel + Render), set the full backend API URL including the /api suffix:
# VITE_API_URL=https://hostelhub-api.onrender.com/api

# Local dev only: where `npm run dev` proxies /api and /uploads (default http://localhost:5000)
# VITE_DEV_API_TARGET=http://localhost:5000
