# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────
# Leave MONGO_URI empty + USE_MEMORY_DB=true to run with an
# in-memory MongoDB (dev only — data resets on restart).
MONGO_URI=mongodb://localhost:27017/hostelhub
USE_MEMORY_DB=true

# ── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Email (Nodemailer) ──────────────────────────────────
# Leave blank in dev — emails are logged to console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="HostelHub <no-reply@hostelhub.com>"

# ── Razorpay ────────────────────────────────────────────
# Leave blank in dev — payments run in mock mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
