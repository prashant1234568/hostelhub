# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separate to allow multiple front-end origins (CORS).
CLIENT_URL=http://localhost:8080,http://localhost:5173

# ── Database ────────────────────────────────────────────
# Leave MONGO_URI empty + USE_MEMORY_DB=true to run with an
# in-memory MongoDB (dev only — data resets on restart).
MONGO_URI=mongodb://localhost:27017/hostelhub
USE_MEMORY_DB=true

# ── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Email (Nodemailer) ──────────────────────────────────
# Leave blank in dev — emails are logged to console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Quarters <no-reply@quarters.app>"

# ── Razorpay ────────────────────────────────────────────
# Leave blank in dev — payments run in mock mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Business identity (printed on rent receipts / invoices) ──
BUSINESS_NAME=Quarters
BUSINESS_ADDRESS=
# Your GST registration number — shown on receipts when set.
BUSINESS_GSTIN=

# ── UPI collections (tenant "scan to pay" QR) ──────────────
# Your collection VPA/UPI ID (e.g. yourpg@okhdfcbank). In dev a demo VPA is
# used so the QR is visible; in production this MUST be set or the QR is hidden.
UPI_VPA=
# Name shown to the payer in their UPI app (defaults to BUSINESS_NAME).
UPI_PAYEE_NAME=
