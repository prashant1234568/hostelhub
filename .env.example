# ── docker-compose secrets ────────────────────────────────────────────────
# Copy to .env (git-ignored) before `docker compose up`.

# REQUIRED in production — generate long random strings, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Public URL the browser uses to reach the web app (CORS allow-list).
CLIENT_URL=http://localhost:8080

# ── Optional integrations (blank = mock/console fallbacks) ─────────────────
# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Quarters <no-reply@quarters.app>

# Razorpay (live online payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Business identity on rent receipts / invoices
BUSINESS_NAME=Quarters
BUSINESS_ADDRESS=
BUSINESS_GSTIN=
